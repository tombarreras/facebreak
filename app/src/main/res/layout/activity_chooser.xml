<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingLeft="@dimen/activity_horizontal_margin"
    android:paddingTop="@dimen/activity_vertical_margin"
    android:paddingRight="@dimen/activity_horizontal_margin"
    android:paddingBottom="@dimen/activity_vertical_margin">

  <ImageView
      android:id="@+id/imageView"
      android:layout_width="390dp"
      android:layout_height="144dp"
      android:layout_marginTop="32dp"
      android:contentDescription="@string/app_name"
      app:srcCompat="@mipmap/ic_launcher" />

  <TextView
      android:layout_width="390dp"
      android:layout_height="wrap_content"
      android:fontFamily="google-sans"
      android:gravity="center|center_horizontal|top"
      android:paddingTop="5dp"
      android:paddingBottom="32dp"
      android:text="@string/app_name"
      android:textColor="@color/white"
      android:textSize="18sp" />

  <Button
      android:id="@+id/stillAnalysis"
      style="@android:style/Widget.Material.Button"
      android:layout_width="188dp"
      android:layout_height="188dp"
      android:background="@android:drawable/ic_menu_gallery"
      android:foreground="?attr/selectableItemBackground"
      android:gravity="bottom|center_horizontal"
      android:minWidth="48dp"
      android:text="Analyze Still Images"
      android:textAllCaps="false" />

  <Button
      android:id="@+id/liveAnalysis"
      style="@android:style/Widget.Material.Button.Inset"
      android:layout_width="188dp"
      android:layout_height="188dp"
      android:background="@android:drawable/ic_menu_view"
      android:foreground="?attr/selectableItemBackground"
      android:gravity="bottom|center"
      android:minWidth="48dp"
      android:text="Analyze Live Video"
      android:textAlignment="center"
      android:textAllCaps="false" />

</LinearLayout>
